<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.FallDetectionApp" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/apple_blue</item>
        <item name="android:windowBackground">@color/white</item>
        <item name="android:statusBarColor">@color/white</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.FallDetectionApp" parent="Base.Theme.FallDetectionApp" />

    <!-- Apple Button Styles -->
    <style name="AppleButtonPrimary" parent="Widget.Material3.Button">
        <item name="android:backgroundTint">@color/apple_blue</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.Apple.Button</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">17sp</item>
    </style>

    <style name="AppleButtonSecondary" parent="Widget.Material3.Button">
        <item name="android:backgroundTint">@color/apple_near_black</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.Apple.Button</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">17sp</item>
    </style>

    <style name="ShapeAppearance.Apple.Button" parent="">
        <item name="cornerSize">8dp</item>
    </style>

    <style name="ShapeAppearance.Apple.Pill" parent="">
        <item name="cornerSize">980dp</item>
    </style>

    <!-- Apple Text Styles -->
    <style name="AppleHeadline" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:textColor">@color/apple_near_black</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">34sp</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <style name="AppleBody" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/apple_near_black</item>
        <item name="android:textSize">17sp</item>
        <item name="android:letterSpacing">-0.01</item>
    </style>

    <style name="AppleLink" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textColor">@color/apple_link_blue</item>
        <item name="android:textSize">14sp</item>
    </style>

</resources>