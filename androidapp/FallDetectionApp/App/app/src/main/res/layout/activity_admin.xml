<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/apple_light_gray">

    <TextView
        style="@style/AppleHeadline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Admin Dashboard"
        android:layout_marginBottom="24dp" />

    <TextView
        style="@style/AppleBody"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="User Management System"
        android:layout_marginBottom="16dp" />

    <!-- Danh sách người dùng sẽ được load ở đây -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/userRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <Button
        android:id="@+id/adminLogoutButton"
        style="@style/AppleButtonSecondary"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Logout Admin"
        android:layout_marginTop="16dp"/>

</LinearLayout>