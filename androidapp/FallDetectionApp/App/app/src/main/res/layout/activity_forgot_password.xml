<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="32dp">

    <ImageView
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_marginTop="48dp"
        android:layout_marginBottom="24dp"
        android:src="@android:drawable/ic_dialog_info"
        app:tint="@color/apple_near_black"
        android:contentDescription="Forgot Password Icon" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Reset Password"
        style="@style/AppleHeadline"
        android:layout_marginBottom="8dp"
        android:gravity="center"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enter your email to receive instructions."
        style="@style/AppleBody"
        android:textColor="@color/apple_text_secondary"
        android:layout_marginBottom="48dp"
        android:gravity="center"/>

    <EditText
        android:id="@+id/emailEditText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Email Address"
        android:inputType="textEmailAddress"
        android:background="@drawable/edit_text_background"
        android:layout_marginBottom="32dp"
        android:textSize="17sp"
        android:autofillHints="emailAddress" />

    <Button
        android:id="@+id/resetButton"
        style="@style/AppleButtonPrimary"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Send Instructions"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:id="@+id/backToSignInTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Back to Sign In"
        style="@style/AppleLink"
        android:padding="8dp"/>

</LinearLayout>